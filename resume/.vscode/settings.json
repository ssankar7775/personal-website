{
  "latex-workshop.latexmk.path": "/Library/TeX/texbin/latexmk",
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "/Library/TeX/texbin/latexmk",
      "env": {
        "PATH": "/Library/TeX/texbin:/usr/bin:/bin:/usr/sbin:/sbin"
      },
      "args": [
        "-g",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdflatex=/Library/TeX/texbin/pdflatex %O %S",
        "-pdf",
        "%DOCFILE%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk (pdf)",
      "tools": [
        "latexmk"
      ]
    }
  ],
  "latex-workshop.latex.clean.command": "/Library/TeX/texbin/latexmk",
  "latex-workshop.latex.recipe.default": "lastUsed"
}
